{
  "name": "agency-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=3001 node scripts/dev-server.mjs",
    "dev:next": "next dev --turbo",
    "build": "prisma generate && next build",
    "build:netlify": "prisma generate && DATABASE_URL_UNPOOLED=\"${DATABASE_URL_UNPOOLED:-$DATABASE_URL}\" PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1 prisma migrate deploy && next build",
    "start": "next start",
    "start:prod": "next start -H 127.0.0.1",
    "db:deploy": "prisma migrate deploy",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:import-sqlite": "tsx scripts/sqlite-to-postgres.ts",
    "db:setup": "prisma migrate dev --name init && tsx prisma/seed.ts",
    "db:ensure": "node scripts/ensure-db.mjs",
    "dev:clean": "rm -rf .next && npm run db:ensure && npm run dev",
    "dev:fix": "lsof -ti :3001 | xargs kill -9 2>/dev/null || true && npm run db:ensure && npm run dev",
    "vercel": "vercel",
    "netlify": "netlify",
    "netlify:deploy": "netlify deploy --build",
    "netlify:deploy:prod": "netlify deploy --prod --build",
    "netlify:dev": "netlify dev",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.39.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.11",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "netlify-cli": "^26.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vercel": "^54.10.1"
  }
}
