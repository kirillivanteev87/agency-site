# Локальная разработка — скопируйте в .env в корне проекта
# cp deploy/env.local.example .env

# PostgreSQL (Neon free tier dev branch, Docker, или локальный Postgres)
# Docker: docker run -d --name agency-pg -e POSTGRES_PASSWORD=dev -e POSTGRES_DB=agency -p 5432:5432 postgres:16
# DATABASE_URL=postgresql://postgres:dev@localhost:5432/agency
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Сессия админки (любая строка для dev)
SESSION_SECRET=local-dev-secret

# Загрузки пишутся в public/uploads и public/video (VERCEL не задан).
# Для теста Blob локально: VERCEL=1 и BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Первый запуск: npm run db:deploy && npm run db:seed
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# SMTP (опционально для теста форм)
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# LEAD_NOTIFY_EMAIL=
