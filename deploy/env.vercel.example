# Шаблон переменных для Vercel (PostgreSQL + Blob)
# Не коммитьте реальные значения. Задайте в Vercel Dashboard → Settings → Environment Variables.
# Production + Preview (и Development при локальном vercel dev).

# Публичный URL сайта (metadata, canonical, Open Graph)
NEXT_PUBLIC_SITE_URL=https://example.ru

# PostgreSQL — Neon, Supabase, Vercel Postgres, REG.RU Cloud PostgreSQL и т.д.
# Neon pooled (runtime): postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler:5432/DATABASE?sslmode=require
# Neon direct (prisma migrate deploy на Vercel — без P1002 advisory lock timeout)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Сессия админки — обязательно уникальная строка (openssl rand -base64 32)
SESSION_SECRET=change-me-to-random-secret

# Vercel Blob — загрузки из админки (изображения, hero-video)
# Dashboard → Storage → Create Blob Store → подключите к проекту (токен подставится автоматически)
# Или вручную: BLOB_READ_WRITE_TOKEN из store settings
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# SMTP — уведомления о заявках (рекомендуется на проде)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=hello@example.ru
SMTP_PASS=app-password-here
SMTP_FROM=hello@example.ru
LEAD_NOTIFY_EMAIL=manager@example.ru

# AI-чат (опционально)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# --- Только для одноразового seed (локально, не в build/runtime) ---
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=strong-password-here

# Не задавайте на Vercel:
# PORT — назначается платформой
# DATABASE_URL=file:... — SQLite не поддерживается
