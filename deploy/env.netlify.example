# Шаблон переменных для Netlify (PostgreSQL + медиа)
# Не коммитьте реальные значения. Задайте в Netlify Dashboard → Project configuration → Environment variables.
# Production + Deploy previews (и локально через `netlify dev` / `netlify env:pull`).

# Публичный URL сайта (metadata, canonical, Open Graph)
NEXT_PUBLIC_SITE_URL=https://qnox.ru

# PostgreSQL — Neon (можно оставить тот же проект, что был на Vercel)
# Pooled — для runtime Prisma
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler:5432/DATABASE?sslmode=require
# Direct — для prisma migrate deploy на build
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Сессия админки — обязательно уникальная строка (openssl rand -base64 32)
SESSION_SECRET=change-me-to-random-secret

# --- Медиа (выберите один вариант) ---

# Вариант A (рекомендуется при миграции с Vercel): оставить Vercel Blob store
# Токен из Vercel Dashboard → Storage → Blob → токен read-write
# Работает с Netlify-хостингом; существующие URL *.blob.vercel-storage.com остаются валидными.
# Поддерживает загрузку видео до 100 МБ.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# Вариант B: только Netlify Blobs (без токена выше)
# Файлы отдаются через /api/media/…; лимит тела запроса функции ~6 МБ — крупные видео не пройдут.
# Для локальной разработки Blobs: netlify dev (или NETLIFY_SITE_ID + NETLIFY_AUTH_TOKEN).

# SMTP — уведомления о заявках (рекомендуется на проде)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=hello@example.ru
SMTP_PASS=app-password-here
SMTP_FROM=hello@example.ru
LEAD_NOTIFY_EMAIL=manager@example.ru

# AI-чат (опционально)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# --- Только для одноразового seed (локально, не в build/runtime) ---
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=strong-password-here

# Не задавайте на Netlify:
# PORT — назначается платформой
# DATABASE_URL=file:... — SQLite не поддерживается
