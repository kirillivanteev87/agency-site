# Скопируйте на сервер как /var/www/agency-site/.env
# cp deploy/env.production.example .env && nano .env

NODE_ENV=production
PORT=3000

# Публичный URL сайта (для metadata, canonical)
NEXT_PUBLIC_SITE_URL=https://example.ru

# SQLite на постоянном диске (абсолютный путь надёжнее относительного)
DATABASE_URL="file:/var/www/agency-site/data/production.db"

# Обязательно смените на длинную случайную строку (openssl rand -base64 32)
SESSION_SECRET=change-me-to-random-secret

# Первый запуск: логин/пароль админки (только для prisma/seed.ts)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=strong-password-here

# SMTP — уведомления о заявках (опционально, но рекомендуется)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=hello@example.ru
SMTP_PASS=app-password-here
SMTP_FROM=hello@example.ru
LEAD_NOTIFY_EMAIL=manager@example.ru

# AI-чат (опционально)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
